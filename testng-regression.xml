<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  REGRESSION SUITE — 10 tests, ~20–30 min
  Covers all detailed scenarios not included in smoke: error cases, sorting, cart operations,
  checkout validation and overview. Run after smoke passes, before merging to main.

  Usage: mvn clean test -DsuiteXmlFile=testng-regression.xml
-->
<suite name="SauceLabs Mobile — Regression" verbose="1" parallel="none">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="com.meghana.appium.listeners.AllureEnvironmentListener"/>
    </listeners>

    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.meghana.appium.tests.LoginTest"/>
            <class name="com.meghana.appium.tests.InventoryTest"/>
            <class name="com.meghana.appium.tests.CartTest"/>
            <class name="com.meghana.appium.tests.CheckoutTest"/>
        </classes>
    </test>

</suite>
